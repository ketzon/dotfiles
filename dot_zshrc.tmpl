# If you come from bash you might have to change your $PATH.
# export PATH=$HOME/bin:$HOME/.local/bin:/usr/local/bin:$PATH

# Path to your Oh My Zsh installation.
export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="robbyrussell"

plugins=(
    git
    zsh-autosuggestions
)

source $ZSH/oh-my-zsh.sh

# FZF keybindings and completion (compatible avec fzf < 0.48)
if [ -f /usr/share/doc/fzf/examples/key-bindings.zsh ]; then
    source /usr/share/doc/fzf/examples/key-bindings.zsh
fi
if [ -f /usr/share/doc/fzf/examples/completion.zsh ]; then
    source /usr/share/doc/fzf/examples/completion.zsh
fi

# FZF configuration
export FZF_DEFAULT_OPTS="--height 60% --layout=reverse --border --margin=1 --padding=1"
# Cherche depuis le home par défaut, ou depuis pwd si spécifié
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git . $HOME'
export FZF_CTRL_T_COMMAND='fd --type f --hidden --follow --exclude .git . $HOME'
export FZF_CTRL_T_OPTS="--preview 'bat --color=always --line-range :500 {} 2>/dev/null || cat {}' --preview-window=right:60%:wrap"
export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git . $HOME'
export FZF_ALT_C_OPTS="--preview 'tree -C -L 1 {} 2>/dev/null || find {} -maxdepth 1 2>/dev/null' --preview-window=right:60%:wrap"
export FZF_TMUX=1
export FZF_TMUX_OPTS="-p 80%,80%"

_comp_options+=(globdots)

if [[ "$(uname)" == "Darwin" ]]; then
    source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
else
    source /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
fi

lazy_load_nvm() {
  unset -f node nvm
  export NVM_DIR="$HOME/.nvm"
  [[ -s "$NVM_DIR/nvm.sh" ]] && source "$NVM_DIR/nvm.sh"
}
node() { lazy_load_nvm; node $@ }
nvm() { lazy_load_nvm; nvm $@ }

# bun completions
[ -s "{{ .chezmoi.homeDir }}/.bun/_bun" ] && source "{{ .chezmoi.homeDir }}/.bun/_bun"

export PATH="$HOME/.local/bin:$PATH"
export PATH="$PATH:/opt/platform-tools"
export PATH={{ .chezmoi.homeDir }}/.opencode/bin:$PATH
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=#555555"
bindkey '^f' autosuggest-accept

# Editor aliases
alias v='nvim'
alias e='emacs -nw'

# Config aliases
alias vconf='nvim ~/.config/nvim/'
alias conf='cd ~/.config/'
alias vimrc='nvim ~/.vimrc'
alias zshrc='nvim ~/.zshrc'
alias tmuxconf='nvim ~/.tmux.conf'
alias dotf='cd ~/.local/share/chezmoi'

# Tool aliases
alias tgpt='terminalgpt'
alias tgpto='terminalgpt one-shot'
alias tgptn='terminalgpt new'
alias planning='v ~/.config/routine/routine.conf'

# Git aliases
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gl='git log --oneline --graph --decorate'

# Utilities
alias ls='ls --color=auto'
alias ll='ls -lah'
alias grep='grep --color=auto'
